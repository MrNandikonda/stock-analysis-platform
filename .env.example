# Core app
APP_NAME=Lightweight Multi-Market Stock Screener
APP_ENV=prod
API_PREFIX=/api/v1
DATABASE_URL=sqlite+aiosqlite:///./data/stocks.db
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173
PUBLIC_HOSTNAMES=localhost 127.0.0.1
FRONTEND_HTTP_PORT=8080
BACKEND_BIND_HOST=127.0.0.1
BACKEND_PORT=8000

# Optional HTTP basic auth (recommended if exposing beyond localhost)
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# Public-domain example:
# PUBLIC_HOSTNAMES=rythumarket.shop www.rythumarket.shop localhost 127.0.0.1
# FRONTEND_HTTP_PORT=80
# CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://rythumarket.shop,https://rythumarket.shop

# Optional Cloudflare Tunnel:
# After you move your domain DNS to Cloudflare and create a tunnel route to http://frontend:80,
# set the tunnel token below and start the compose "tunnel" profile.
CLOUDFLARED_TUNNEL_TOKEN=

# Data source controls
YFINANCE_HOURLY_LIMIT=2000
API_RATE_LIMIT_PER_MINUTE=120

# Runtime behavior
RUN_SCHEDULER_IN_API=false

# AI analysis subsystem
AI_ANALYSIS_ENABLED=true
AI_DEFAULT_PROVIDER=local-summary
AI_DEFAULT_SCHEDULE_MINUTES=60
AI_DEFAULT_STALE_AFTER_MINUTES=180
AI_MAX_STOCKS_PER_JOB=15
AI_MAX_PARALLEL_AGENTS=2
AI_JOB_STALE_MINUTES=90
AI_WEB_SEARCH_ENABLED=false
AI_BACKGROUND_MODE_ENABLED=false

# OpenAI provider (optional; only needed when using provider_name=openai)
OPENAI_API_KEY=
OPENAI_API_BASE_URL=
OPENAI_MODEL_ORCHESTRATOR=gpt-5.4-mini
OPENAI_MODEL_SPECIALIST=gpt-5.4-mini
OPENAI_MODEL_SUMMARIZER=gpt-5.4-mini

# Frontend build-time variable
VITE_API_BASE_URL=/api/v1
